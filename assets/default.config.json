{
  "repo": "",
  "defaultTargetBranch": "master",
  "branchPrefix": "fix",
  "branchNaming": {
    "mode": "from-target-branch-template",
    "replaceFirstSegmentWith": "git-user-digits",
    "replaceLastSegmentWith": "feature-slug",
    "fallbackPattern": "fix/{td_id}-{feature_slug}"
  },
  "installedSkills": {
    "tdQuery": {
      "name": "td-detail-query",
      "notes": "Installed skill name used conversationally inside the AI CLI to query TD details."
    },
    "createMr": {
      "name": "create-mr",
      "notes": "Installed skill name used conversationally inside the AI CLI to create a GitLab MR."
    }
  },
  "orchestration": {
    "mode": "single-agent",
    "notes": "Default to a single orchestrating agent. Add multi-agent only after the baseline workflow is stable."
  },
  "planConfirmation": {
    "required": true,
    "notes": "Always present the repair plan to the user and wait for confirmation before modifying code."
  },
  "cache": {
    "directory": ".td-fix-cache"
  },
  "verify": {
    "lint": "",
    "typecheck": "",
    "test": "",
    "strategy": "self-authored"
  },
  "paths": {
    "src": [
      "src"
    ],
    "tests": [
      "tests",
      "__tests__"
    ],
    "docs": [
      "docs",
      "knowledge"
    ]
  },
  "knowledgeBase": {
    "docFiles": [
      "项目概述.md",
      "环境配置与部署.md",
      "系统架构设计.md",
      "服务层详解.md"
    ],
    "docExtensions": [
      ".md",
      ".mdx"
    ],
    "codeExtensions": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".java",
      ".py",
      ".go"
    ],
    "maxCandidateFiles": 12,
    "maxSimilarChanges": 5
  },
  "history": {
    "maxCommits": 200
  },
  "riskRules": {
    "maxChangedFiles": 8,
    "forbiddenPaths": [
      "db/migration",
      "api/public"
    ]
  },
  "mr": {
    "draft": true,
    "targetBranchConfirmation": true,
    "labels": [
      "ai-fix",
      "td"
    ]
  }
}
